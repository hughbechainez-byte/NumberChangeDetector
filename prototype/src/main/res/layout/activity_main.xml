<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="16dp"
        android:paddingTop="12dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prototype_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/backgroundStatusBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1F3A5F"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/selectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Select Video" />

        <TextView
            android:id="@+id/selectedVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="No video selected"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/roiStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="ROI setup: select a video"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Video preview (scrub, then capture frame for ROI selection)" />

        <VideoView
            android:id="@+id/videoPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp" />

        <SeekBar
            android:id="@+id/previewSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/captureFrameButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Capture frame from current position" />

        <FrameLayout
            android:id="@+id/frameContainer"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/frameImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:background="#111" />

            <View
                android:id="@+id/roiOverlay"
                android:layout_width="120dp"
                android:layout_height="80dp"
                android:layout_gravity="top|left"
                android:background="@drawable/roi_overlay_border"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tap on frame to move ROI box center"
            android:textSize="12sp" />

        <Button
            android:id="@+id/refreshRoiButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Refresh ROI" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Detection area (percent of frame: X,Y,Width,Height)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <EditText
                android:id="@+id/scanAreaX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X"
                android:inputType="numberDecimal"
                android:text="0" />

            <EditText
                android:id="@+id/scanAreaY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y"
                android:inputType="numberDecimal"
                android:text="80" />

            <EditText
                android:id="@+id/scanAreaWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="W"
                android:inputType="numberDecimal"
                android:text="10" />

            <EditText
                android:id="@+id/scanAreaHeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="H"
                android:inputType="numberDecimal"
                android:text="30" />

        </LinearLayout>

        <TextView
            android:id="@+id/qualityLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Quality"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/qualityPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/formatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Output format"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/formatPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/scanIntervalLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Scan interval" />

        <Spinner
            android:id="@+id/scanSpeedPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/experimentalModeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Scanner mode" />

        <CheckBox
            android:id="@+id/experimentalModeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Experimental Fast ROI Scan"
            android:visibility="gone"
            android:checked="false" />

        <TextView
            android:id="@+id/experimentalDownscaleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Experimental downscale size"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/experimentalDownscalePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/experimentalModeWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:text="Experimental Fast ROI Scan may be faster but can miss or misread changes. If it fails, the app will fall back to stable checkpoint scan." />

        <TextView
            android:id="@+id/transitionStyleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Transitions" />

        <Spinner
            android:id="@+id/transitionStylePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/processButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Build Compilation" />

        <LinearLayout
            android:id="@+id/compilationPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/compilationPreviewLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Compilation preview"
                android:textStyle="bold" />

            <VideoView
                android:id="@+id/compilationPreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="8dp" />

            <SeekBar
                android:id="@+id/compilationPreviewSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:enabled="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/playCompilationPreviewButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Play" />

                <Button
                    android:id="@+id/saveCompilationButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Save" />

                <Button
                    android:id="@+id/discardCompilationButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Discard" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/shareCompilationButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Share" />

                <Button
                    android:id="@+id/openCompilationButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Open" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/transitionResultsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/transition_results_label"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/transitionResultsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#15202B"
            android:padding="10dp"
            android:text="@string/transition_results_empty"
            android:textColor="#FFFFFF"
            android:textIsSelectable="true"
            android:textSize="12sp" />

        <Button
            android:id="@+id/checkUpdatesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Check for updates" />

        <TextView
            android:id="@+id/updateStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="12sp" />

        <Button
            android:id="@+id/crashLogButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Open log" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.Material.Light.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="100"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/progressPercentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="0%"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ready"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusFeedLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status feed"
            android:textSize="12sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/coreStatusSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:text="Show rapid core activity log"
            android:textSize="12sp" />

        <ScrollView
            android:id="@+id/statusFeedScroll"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="6dp"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/statusFeedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="140dp"
                android:padding="8dp"
                android:text=""
                android:textSize="12sp" />
        </ScrollView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/pipStatusContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#101820"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/pipPhaseText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="FOREGROUND SCAN"
                android:textAllCaps="true"
                android:textColor="#80CBC4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pipPercentText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pipProgressBar"
            style="@android:style/Widget.Material.Light.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4DB6AC" />

        <TextView
            android:id="@+id/pipStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Preparing compilation"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pipSignalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Foreground worker ENQUEUED"
            android:textColor="#A7C7D9"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/pipLogText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="3dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="3"
            android:text="Waiting for worker signal"
            android:textColor="#B0BEC5"
            android:textSize="9sp" />
    </LinearLayout>

</FrameLayout>
